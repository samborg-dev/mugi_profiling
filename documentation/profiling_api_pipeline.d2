direction: down

title: Profiling API — pipeline stages {
  near: top-center
  shape: text
  style: { font-size: 26; bold: true }
}

# external touchpoints (defined fully in their own diagrams)
ProfileConfig: { style.stroke-dash: 4 }
Tap: { style.stroke-dash: 4 }
WindowStrategy: { style.stroke-dash: 4 }
WindowConfig: { shape: page; style.stroke-dash: 4 }

ProfilingPipeline: {
  shape: class
  "+run(cfg)": WindowConfig
  "reuses": "facade (new)"
}
ModelLoader: {
  shape: class
  "+load()": "(model, dataset)"
  "reuses": "any HF model"
}
Exporter: {
  shape: class
  "+export(model_id)": onnx_path
  "reuses": "export_onnx (Optimum)"
}
OnnxOpList: {
  shape: class
  "+classify()": "[]ProfileTarget"
  "reuses": "ONNX op-type classify"
}
Instrumentor: {
  shape: class
  "+attach(model, targets)": "[]Tap"
  "+detach()": void
  "reuses": "model_adapters registry"
}
ProfilingRunner: {
  shape: class
  "+run(model, taps, n)": void
  "reuses": run_inference
}
DistributionStore: {
  shape: class
  "+put(layer, op, hist)": void
  "+all()": "[]ExponentDistribution"
  "reuses": "profile/ dump"
}
WindowSizer: {
  shape: class
  "+size(dists)": "[]WindowSpec"
  "reuses": profile_tensor
}
ConfigEmitter: {
  shape: class
  "+emit(specs)": WindowConfig
  "reuses": create_nonlinear_config
}

ProfileConfig -> ProfilingPipeline: configures
ProfilingPipeline -> ModelLoader: 1 load
ProfilingPipeline -> Exporter: 2 export
ProfilingPipeline -> OnnxOpList: 3 parse ops
ProfilingPipeline -> Instrumentor: 4 instrument
ModelLoader -> Exporter: model
Exporter -> OnnxOpList: onnx
OnnxOpList -> Instrumentor: targets
ModelLoader -> Instrumentor: model
Instrumentor -> Tap: creates
ProfilingPipeline -> ProfilingRunner: 5 run xN
Instrumentor -> ProfilingRunner: taps
ProfilingRunner -> DistributionStore: exp dists
ProfilingPipeline -> WindowSizer: 6 size
DistributionStore -> WindowSizer: dists
WindowSizer -> WindowStrategy: uses
ProfilingPipeline -> ConfigEmitter: 7 emit
WindowSizer -> ConfigEmitter: specs
ConfigEmitter -> WindowConfig: writes
