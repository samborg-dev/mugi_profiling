direction: down

title: Profiling API — pipeline stages {
  near: top-center
  shape: text
  style: { font-size: 26; bold: true }
}

# external touchpoints (defined fully in their own diagrams)
ProfileConfig: { style.stroke-dash: 4 }
WindowStrategy: { style.stroke-dash: 4 }
WindowConfig: { shape: page; style.stroke-dash: 4 }
Workload: { shape: page; style.stroke-dash: 4 }

ProfilingPipeline: {
  shape: class
  "+run()": "{profile_dir, onnx_dir, nonlinear_config, archx_workload}"
  "constructed": "ProfilingPipeline(cfg)"
  "reuses": "facade (new)"
}
ModelLoader: {
  shape: class
  "+load(cfg)": model
  "reuses": "model_script modality dispatch"
}
Exporter: {
  shape: class
  "+export(cfg)": onnx_dir
  "reuses": "export_onnx (Optimum)"
}
ProfilingRunner: {
  shape: class
  "+run(model)": void
  "reuses": "InferenceModel.loop_configuration()"
}
DistributionStore: {
  shape: class
  "+tensor_dirs()": "[]leaf dir"
  "reuses": "profile/ dump"
}
WindowSizer: {
  shape: class
  "+size(store)": "[]WindowSpec"
  "reuses": "profile_tensor core"
}
ConfigEmitter: {
  shape: class
  "+emit(store)": WindowConfig
  "reuses": create_nonlinear_config
}
ArchxWorkloadEmitter: {
  shape: class
  "+emit_from_onnx(onnx_dir)": Workload
  "+emit(model)": Workload
  "reuses": "model_shape + ProfileConfig archx knobs"
}

ProfileConfig -> ProfilingPipeline: configures
ProfilingPipeline -> ModelLoader: 1 load
ProfilingPipeline -> Exporter: 2 export
ProfilingPipeline -> ProfilingRunner: 3 profile
ProfilingPipeline -> ConfigEmitter: 4 emit
ProfilingPipeline -> ArchxWorkloadEmitter: 5 convert
ModelLoader -> Exporter: model
ModelLoader -> ProfilingRunner: model
ProfilingRunner -> DistributionStore: exp dists
DistributionStore -> WindowSizer: leaf dirs
WindowSizer -> WindowStrategy: uses
WindowSizer -> ConfigEmitter: specs
Exporter -> ArchxWorkloadEmitter: onnx dir
ConfigEmitter -> WindowConfig: writes
ArchxWorkloadEmitter -> Workload: writes
