direction: down

title: Profiling API — window strategies & criteria {
  near: top-center
  shape: text
  style: { font-size: 26; bold: true }
}

WindowSizer: { style.stroke-dash: 4 }

# --- strategy: HOW to scan window positions ---
WindowStrategy: {
  shape: class
  "+place(dist, criterion)": WindowSpec
}
TopKWindow: { shape: class; "reuses": topk_window_until_threshold; "status": default }
BruteForceWindow: { shape: class; "status": stub }
GreedyWindow: { shape: class; "status": stub }
WindowStrategy -> TopKWindow: is-a { target-arrowhead.shape: triangle }
WindowStrategy -> BruteForceWindow: is-a { target-arrowhead.shape: triangle }
WindowStrategy -> GreedyWindow: is-a { target-arrowhead.shape: triangle }

# --- criterion: WHICH cluster the window is placed on (Dr. Wu: keep swappable) ---
WindowCriterion: {
  shape: class
  "+score(window)": float
}
AutoCluster: { shape: class; "picks": "denser side"; "status": default }
MaxCluster: { shape: class; "reuses": "profile_tensor cluster=max" }
MinCluster: { shape: class; "reuses": "profile_tensor cluster=min" }
Centroid: { shape: class; "status": stub }
WindowCriterion -> AutoCluster: is-a { target-arrowhead.shape: triangle }
WindowCriterion -> MaxCluster: is-a { target-arrowhead.shape: triangle }
WindowCriterion -> MinCluster: is-a { target-arrowhead.shape: triangle }
WindowCriterion -> Centroid: is-a { target-arrowhead.shape: triangle }

WindowSpec: {
  shape: class
  "argmax_value / tensor": ""
  "max_exp / min_exp": "(+ unclamped)"
  "mean / median / centroid": ""
  cluster: "max | min"
}

calibration: {
  shape: class
  "window_calibration": Llama2_7B
  "delegates to": "original profile_tensor"
  "output": "bit-for-bit identical"
}

WindowSizer -> WindowStrategy: search
WindowSizer -> WindowCriterion: criterion
WindowSizer -> calibration: or bypass via calibration
WindowStrategy -> WindowSpec: produces
