direction: down

title: Mugi Profiling API — internals {
  near: top-center
  shape: text
  style: { font-size: 26; bold: true }
}

features: |md
  ### Features / flags
  - **model-agnostic** export - any HF model -> ONNX (Optimum)
  - **two sim inputs** - nonlinear_config.yaml (accuracy) + archx workload.yaml (cost)
  - **ONNX -> archx converter** - archx keeps its own YAML for arbitrary workloads
  - **additive** - delegates to the existing inference lifecycle; instrumentation unchanged
  - **pluggable window** - strategy (TopK / BruteForce / Greedy) x criterion (auto / max / min / centroid)
  - **calibration bypass** - Llama2_7B == original profile_tensor, bit-for-bit
  - **extensible**: new model = 1 adapter, new method = 1 strategy/criterion
|
features.near: top-left

knobs: {
  ProfileConfig: {
    shape: class
    "model / data": "model_id, modality, dataset, n_samples, batch_size"
    export: "onnx_path, export_task, export_opset, emit_onnx"
    window: "window_size, exp_dim, lut_window_size, strategy, criterion, calibration"
    archx: "bitwidths, lut_*, array_config, variant, workload_format, seq lens"
    numeric: "dtype, quantization, kv_quant_dim, profile_targets"
    source: "model_dict, nonlinear_dict, parameter_dict (+ from_configs)"
  }
}

pipeline: {
  ProfilingPipeline: {
    shape: class
    "+run()": "{profile_dir, onnx_dir, nonlinear_config, archx_workload}"
    "constructed": "ProfilingPipeline(cfg)"
    "reuses": "facade (new)"
  }
  ModelLoader: {
    shape: class
    "+load(cfg)": model
    "reuses": "model_script modality dispatch"
  }
  Exporter: {
    shape: class
    "+export(cfg)": onnx_dir
    "reuses": "export_onnx (Optimum)"
  }
  ProfilingRunner: {
    shape: class
    "+run(model)": void
    "reuses": "InferenceModel.loop_configuration()"
  }
  DistributionStore: {
    shape: class
    "+tensor_dirs()": "[]leaf dir"
    "reuses": "profile/ dump"
  }
  WindowSizer: {
    shape: class
    "+size(store)": "[]WindowSpec"
    "reuses": "profile_tensor core"
  }
  ConfigEmitter: {
    shape: class
    "+emit(store)": WindowConfig
    "reuses": create_nonlinear_config
  }
  ArchxWorkloadEmitter: {
    shape: class
    "+emit_from_onnx(onnx_dir)": Workload
    "+emit(model)": Workload
    "reuses": "model_shape + archx knobs"
  }
  ModelShape: {
    shape: class
    "+model_shape_fields(config)": "dim, hidden_dim, heads, kv_heads, layers, vocab"
    "supports": "llama (is_llm) / whisper / swinv2 / vivit"
  }
}

instrumentation: {
  InferenceModel: {
    shape: class
    "+loop_configuration()": void
    "+patch_model(fn, ...)": void
    "reuses": "existing inference lifecycle"
  }
  ModelAdapter: {
    shape: class
    "+layer_sites(host)": "[]LayerSite"
    "reuses": "Llama/Whisper/Swinv2/Vivit adapters"
  }
  VLPNonlinear: {
    shape: class
    "reuses": "custom_approx VLP classes"
    "writes": "exp_dist/layer_N/*.pt"
  }
  InferenceModel -> ModelAdapter: get_adapter(model)
  InferenceModel -> VLPNonlinear: swaps in attention/ffn class
}

strategies: {
  WindowStrategy: {
    shape: class
    "+place(dist, criterion)": WindowSpec
  }
  TopKWindow: { shape: class; "reuses": topk_window_until_threshold; "status": default }
  BruteForceWindow: { shape: class; "status": stub }
  GreedyWindow: { shape: class; "status": stub }
  WindowStrategy -> TopKWindow: is-a { target-arrowhead.shape: triangle }
  WindowStrategy -> BruteForceWindow: is-a { target-arrowhead.shape: triangle }
  WindowStrategy -> GreedyWindow: is-a { target-arrowhead.shape: triangle }

  WindowCriterion: {
    shape: class
    "+score(window)": float
  }
  AutoCluster: { shape: class; "picks": "denser side"; "status": default }
  MaxCluster: { shape: class }
  MinCluster: { shape: class }
  Centroid: { shape: class; "status": stub }
  WindowCriterion -> AutoCluster: is-a { target-arrowhead.shape: triangle }
  WindowCriterion -> MaxCluster: is-a { target-arrowhead.shape: triangle }
  WindowCriterion -> MinCluster: is-a { target-arrowhead.shape: triangle }
  WindowCriterion -> Centroid: is-a { target-arrowhead.shape: triangle }
}

outputs: {
  WindowConfig: { shape: class; file: nonlinear_config.yaml }
  Workload: { shape: class; file: workload.yaml }
  func: "functional sim -> accuracy" { shape: page }
  archx: "archx -> cycles / energy / area" { shape: page }
  WindowConfig -> func: consumed by
  Workload -> archx: consumed by
}

knobs.ProfileConfig -> pipeline.ProfilingPipeline: configures
pipeline.ProfilingPipeline -> pipeline.ModelLoader: 1 load
pipeline.ProfilingPipeline -> pipeline.Exporter: 2 export
pipeline.ProfilingPipeline -> pipeline.ProfilingRunner: 3 profile
pipeline.ProfilingPipeline -> pipeline.ConfigEmitter: 4 emit
pipeline.ProfilingPipeline -> pipeline.ArchxWorkloadEmitter: 5 convert
pipeline.ModelLoader -> pipeline.Exporter: model
pipeline.ProfilingRunner -> instrumentation.InferenceModel: delegates { style.stroke-dash: 3 }
instrumentation.VLPNonlinear -> pipeline.DistributionStore: exp dists
pipeline.DistributionStore -> pipeline.WindowSizer: leaf dirs
pipeline.WindowSizer -> strategies.WindowStrategy: search
pipeline.WindowSizer -> strategies.WindowCriterion: criterion
pipeline.WindowSizer -> pipeline.ConfigEmitter: specs
pipeline.Exporter -> pipeline.ArchxWorkloadEmitter: onnx dir
pipeline.ModelShape -> pipeline.ArchxWorkloadEmitter: shape fields
pipeline.ConfigEmitter -> outputs.WindowConfig: writes
pipeline.ArchxWorkloadEmitter -> outputs.Workload: writes
