direction: right

title: Mugi toolchain — where the profiling frontend fits {
  near: top-center
  shape: text
  style: { font-size: 22; bold: true }
}

model: "any HF model" { shape: oval }

frontend: "Profiling frontend  (Sam)" {
  onnx: "ONNX export" { shape: page }
  converter: "ONNX -> archx converter" { shape: hexagon }
  workload: "archx workload.yaml" { shape: page }
  config: "nonlinear_config.yaml" { shape: page }

  onnx -> converter
  converter -> workload
}

sims: "Simulators  (Daniel)" {
  func: "functional sim -> accuracy / perplexity" { shape: page }
  archx: "archx -> cycles / energy / area" { shape: page }
}

backend: "Hardware tool chain" {
  isa: "ISA -> machine code  (Grig)"
  array: "systolic array RTL  (Arya)"
  proc: "RISC-V processor  (Josh)"
  isa -> array: dispatch
  isa -> proc: dispatch
}

fpga: "FPGA demo / OpenROAD synth" { shape: hexagon }

model -> frontend.onnx: export
model -> frontend.config: profile over real data
frontend.workload -> sims.archx
frontend.config -> sims.func
frontend.config -> backend.isa: window config
backend.array -> fpga
backend.proc -> fpga
sims.archx -> fpga: cost model { style.stroke-dash: 4 }
