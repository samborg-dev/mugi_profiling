direction: down

title: Profiling API — instrumentation {
  near: top-center
  shape: text
  style: { font-size: 26; bold: true }
}

ProfilingRunner: { style.stroke-dash: 4 }

InferenceModel: {
  shape: class
  "+loop_configuration()": void
  "+patch_model(fn, ...)": void
  "-_apply_adapter(...)": n_patched
  "-_apply_legacy(...)": n_patched
  "reuses": "existing inference lifecycle"
}

ModelAdapter: {
  shape: class
  "+matches(model)": bool
  "+layer_sites(host)": "[]LayerSite"
  "+expected_count(model)": int
  "reuses": "Llama/Whisper/Swinv2/Vivit adapters"
}

LayerSite: {
  shape: class
  "host / attr / layer_idx": "attn + ffn sites"
}

VLPNonlinear: {
  shape: class
  "reuses": "custom_approx VLP classes"
  "writes": "exp_dist/layer_N/*.pt"
}

dump: "profile/<model>/ exponent histograms" { shape: page }

ProfilingRunner -> InferenceModel: delegates { style.stroke-dash: 3 }
InferenceModel -> ModelAdapter: get_adapter(model)
ModelAdapter -> LayerSite: locates attn/ffn sites
InferenceModel -> VLPNonlinear: swaps in attention/ffn class
VLPNonlinear -> dump: writes
